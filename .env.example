# HTTP listen address
LISTEN_ADDR=:8080

# --- GitHub App authentication (recommended for production) ---
# GITHUB_APP_ID=123456
# GITHUB_INSTALLATION_ID=987654
# GITHUB_PRIVATE_KEY_PATH=/path/to/private-key.pem

# --- Personal Access Token (dev fallback) ---
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Commit identity used for PRs opened by this service
GIT_AUTHOR_NAME=machinery-catalog-locator
GIT_AUTHOR_EMAIL=machinery-catalog-locator@local
